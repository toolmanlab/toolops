# ToolOps Environment Configuration
# Copy this file to .env and fill in your values

# ── Vector Store ──────────────────────────────────────────────
TOOLOPS_VECTORSTORE=chroma          # chroma | milvus | qdrant

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./.chroma

# ── Cache ─────────────────────────────────────────────────────
TOOLOPS_CACHE=memory                # memory | redis

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Monitor ───────────────────────────────────────────────────
TOOLOPS_MONITOR=null                # null | phoenix

# Arize Phoenix
PHOENIX_HOST=localhost
PHOENIX_PORT=6006
PHOENIX_API_KEY=

# ── General ───────────────────────────────────────────────────
TOOLOPS_ENV=local                   # local | server | cloud
TOOLOPS_LOG_LEVEL=INFO
