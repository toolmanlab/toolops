# ToolOps Configuration — generated by `toolops init`
# Edit manually or re-run `toolops init` to regenerate.

# ── Active backends ───────────────────────────────────────────
vectorstore: {{ vectorstore }}   # chroma | milvus | qdrant
cache: {{ cache }}               # memory | redis
monitor: {{ monitor }}           # null | phoenix
env: {{ env }}                   # local | server | cloud

log_level: INFO

{% if vectorstore == "milvus" %}
# ── Milvus ────────────────────────────────────────────────────
milvus:
  host: {{ milvus_host | default("localhost") }}
  port: {{ milvus_port | default(19530) }}
  token: ""                      # set via MILVUS_TOKEN env var
{% elif vectorstore == "qdrant" %}
# ── Qdrant ────────────────────────────────────────────────────
qdrant:
  host: {{ qdrant_host | default("localhost") }}
  port: {{ qdrant_port | default(6333) }}
  api_key: ""                    # set via QDRANT_API_KEY env var
{% else %}
# ── Chroma ────────────────────────────────────────────────────
chroma:
  host: {{ chroma_host | default("localhost") }}
  port: {{ chroma_port | default(8000) }}
  persist_dir: {{ chroma_persist_dir | default("./.chroma") }}
{% endif %}

{% if cache == "redis" %}
# ── Redis ─────────────────────────────────────────────────────
redis:
  host: {{ redis_host | default("localhost") }}
  port: {{ redis_port | default(6379) }}
  password: ""                   # set via REDIS_PASSWORD env var
  db: 0
{% endif %}

{% if monitor == "phoenix" %}
# ── Arize Phoenix ─────────────────────────────────────────────
phoenix:
  host: {{ phoenix_host | default("localhost") }}
  port: {{ phoenix_port | default(6006) }}
  api_key: ""                    # set via PHOENIX_API_KEY env var
{% endif %}
